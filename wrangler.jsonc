{
	"$schema": "node_modules/wrangler/config-schema.json",
	"main": ".open-next/worker.js",
	"name": "travel-guide",
	"compatibility_date": "2026-06-30",
	"compatibility_flags": [
		"nodejs_compat",
		"global_fetch_strictly_public"
	],
	"assets": {
		"directory": ".open-next/assets",
		"binding": "ASSETS"
	},
	"services": [
		{
			// Self-reference service binding, the service name must match the worker name
			// see https://opennext.js.org/cloudflare/caching
			"binding": "WORKER_SELF_REFERENCE",
			"service": "travel-guide"
		}
	],
	"images": {
		// Enable image optimization
		// see https://opennext.js.org/cloudflare/howtos/image
		"binding": "IMAGES"
	},
	"vars": {
		"DEEPSEEK_BASE_URL": "https://api.deepseek.com",
		"NEXT_PUBLIC_SITE_URL": "https://travel-guide.travel-guide-cn.workers.dev"
	},
	"observability": {
		"enabled": true
	}
}